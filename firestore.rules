rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function myEmail()  { return request.auth.token.email; }
    function spaceData(spaceId) {
      return get(/databases/$(database)/documents/spaces/$(spaceId)).data;
    }
    function isMember(spaceId) {
      return signedIn() && request.auth.uid in spaceData(spaceId).members;
    }

    // ---- A couple's space ----
    match /spaces/{spaceId} {
      // Only members can read.
      allow read: if signedIn() && request.auth.uid in resource.data.members;

      // Creator must be the owner and a member.
      allow create: if signedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && request.auth.uid in request.resource.data.members;

      // Existing members can update; OR an invited user may add themselves.
      allow update: if signedIn() && (
        request.auth.uid in resource.data.members
        || (myEmail() in resource.data.invitedEmails
            && request.auth.uid in request.resource.data.members)
      );

      allow delete: if signedIn() && request.auth.uid == resource.data.ownerUid;

      // All app data lives in sub-collections; only members may touch it.
      match /{sub}/{docId} {
        allow read, write: if isMember(spaceId);
      }
    }

    // ---- Invites (doc id == invitee's email) ----
    match /invites/{inviteEmail} {
      // A member of the target space can create/update/remove the invite.
      allow create, update: if signedIn() && isMember(request.resource.data.spaceId);
      // The invitee can read (to discover their space) and delete after joining;
      // a member of the target space can also clean it up.
      allow read: if signedIn() && inviteEmail == myEmail();
      allow delete: if signedIn() && (inviteEmail == myEmail() || isMember(resource.data.spaceId));
    }
  }
}
